# Секрет расширения — скопировать из Twitch Dev Console → Extensions → Settings → Extension Secret
# Это base64-строка, не декодировать вручную
EXTENSION_SECRET=base64_secret_from_twitch_dev_console

# Client ID расширения (Twitch Dev Console → Extensions → Settings)
CLIENT_ID=your_extension_client_id

# User ID владельца расширения (твой Twitch user ID, нужен для подписи EBS JWT)
# Получить: curl -H "Authorization: Bearer <token>" https://api.twitch.tv/helix/users?login=твой_логин
OWNER_USER_ID=your_twitch_user_id

# Порт сервера
PORT=3000

# Установить true для локального тестирования — PubSub вызов заменяется логом в консоль
MOCK_PUBSUB=true
